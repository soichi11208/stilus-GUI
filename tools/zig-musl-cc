#!/bin/sh
# Meson probes the linker by invoking the compiler with `-Wl,--version` and
# parsing the printed banner. Since zig 0.15 the banner is "zig ld 0.15.1",
# which Meson doesn't recognise, so it aborts with
# "Unable to detect linker for compiler". zig cc's actual linker IS LLD, so
# we short-circuit that specific probe with a Meson-parseable LLD string.
for a in "$@"; do
    if [ "$a" = "-Wl,--version" ]; then
        echo "LLD 15.0.0 (compatible with GNU linkers)"
        exit 0
    fi
done
exec zig cc -target x86_64-linux-musl "$@"
